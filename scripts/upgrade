#!/bin/bash

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# STOP SERVICE
#=================================================
ynh_script_progression --message="Stopping $app service..." --weight=1

ynh_systemd_action --service_name="$app" --action=stop --log_path=systemd || true

#=================================================
# COPY SOURCES
#=================================================
ynh_script_progression --message="Upgrading application files..." --weight=3

ynh_copy_app_sources "$install_dir"

#=================================================
# UPDATE PYTHON DEPENDENCIES
#=================================================
ynh_script_progression --message="Updating Python dependencies..." --weight=10

if [ ! -d "$install_dir/venv" ]; then
    python3 -m venv "$install_dir/venv"
fi
"$install_dir/venv/bin/pip" install --quiet --upgrade pip
"$install_dir/venv/bin/pip" install --quiet -r "$install_dir/backend/requirements.txt"

#=================================================
# REGENERATE CONFIGURATION
#=================================================
ynh_script_progression --message="Updating configuration..." --weight=1

# Read existing API key from settings (do not rotate it on upgrade)
api_key=$(ynh_app_setting_get --app="$app" --key=api_key)

cat > "$install_dir/.env" <<EOF
MUSCU_API_KEY=$api_key
MUSCU_DB_PATH=$data_dir/muscu.db
MUSCU_FRONTEND_DIR=$install_dir/frontend
EOF
chmod 640 "$install_dir/.env"
chown "$app:$app" "$install_dir/.env"
chown -R "$app:$app" "$install_dir"

#=================================================
# SYSTEMD & NGINX
#=================================================
ynh_script_progression --message="Updating systemd and NGINX configuration..." --weight=2

ynh_add_systemd_config
ynh_add_nginx_config
ynh_systemd_action --service_name="$app" --action=start --log_path=systemd --line_match="Application startup complete"

#=================================================
# END
#=================================================
ynh_script_progression --message="Upgrade of $app completed!" --last
