#!/bin/bash

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# COPY APP SOURCES
#=================================================
ynh_script_progression --message="Setting up application files..." --weight=3

ynh_copy_app_sources "$install_dir"

#=================================================
# PYTHON VIRTUAL ENVIRONMENT
#=================================================
ynh_script_progression --message="Creating Python virtual environment..." --weight=10

python3 -m venv "$install_dir/venv"
"$install_dir/venv/bin/pip" install --quiet --upgrade pip
"$install_dir/venv/bin/pip" install --quiet -r "$install_dir/backend/requirements.txt"

#=================================================
# CONFIGURATION
#=================================================
ynh_script_progression --message="Generating configuration..." --weight=1

api_key=$(ynh_string_random --length=32)
ynh_app_setting_set --app="$app" --key=api_key --value="$api_key"

cat > "$install_dir/.env" <<EOF
MUSCU_API_KEY=$api_key
MUSCU_DB_PATH=$data_dir/muscu.db
MUSCU_FRONTEND_DIR=$install_dir/frontend
EOF
chmod 640 "$install_dir/.env"
chown "$app:$app" "$install_dir/.env"

#=================================================
# SYSTEMD
#=================================================
ynh_script_progression --message="Configuring systemd service..." --weight=1

ynh_add_systemd_config
ynh_systemd_action --service_name="$app" --action=start --log_path=systemd --line_match="Application startup complete"

#=================================================
# NGINX
#=================================================
ynh_script_progression --message="Configuring NGINX web server..." --weight=1

ynh_add_nginx_config

#=================================================
# END
#=================================================
ynh_script_progression --message="Installation of $app completed!" --last
